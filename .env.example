# ==========================================
# AI Model Configuration (Text/Brains)
# ==========================================

# Default Provider (Fallback if an agent specific override is not set)
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4-turbo

# API Keys for Text Providers (LiteLLM handles routing)
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GEMINI_API_KEY=your_gemini_api_key
COHERE_API_KEY=your_cohere_api_key
MISTRAL_API_KEY=your_mistral_api_key
KIMI_API_KEY=your_kimi_api_key
HUGGINGFACE_API_KEY=your_huggingface_api_key
REPLICATE_API_TOKEN=your_replicate_api_token

# Agent-Specific Model Overrides
# Format: provider/model_name (e.g., anthropic/claude-3-opus, gemini/gemini-1.5-pro, mistral/mistral-large)
DISCOVERY_AGENT_LLM=openai/gpt-4-turbo
CONTENT_AGENT_LLM=openai/gpt-4-turbo
ANALYTICS_AGENT_LLM=openai/gpt-4-turbo
INTELLIGENCE_AGENT_LLM=openai/gpt-4-turbo
ERPNEXT_AGENT_LLM=openai/gpt-4-turbo
PUBLISHING_AGENT_LLM=openai/gpt-4-turbo
INTERACTION_AGENT_LLM=openai/gpt-4-turbo

# ==========================================
# Media Generation (Images & Video Tools)
# ==========================================

# Image Generation API Keys
STABILITY_API_KEY=your_stability_api_key
ADOBE_FIREFLY_API_KEY=your_adobe_firefly_api_key
IDEOGRAM_API_KEY=your_ideogram_api_key
LEONARDO_API_KEY=your_leonardo_api_key

# Video Generation API Keys
RUNWAY_API_KEY=your_runway_api_key
LUMA_API_KEY=your_luma_api_key
PIKA_API_KEY=your_pika_api_key
HEYGEN_API_KEY=your_heygen_api_key
SYNTHESIA_API_KEY=your_synthesia_api_key

# Preferred Media Providers
PREFERRED_IMAGE_PROVIDER=gemini # Options: gemini, openai, stability, replicate, ideogram
PREFERRED_VIDEO_PROVIDER=gemini # Options: gemini, runway, luma, pika, heygen

# ==========================================
# Integrations Configuration
# ==========================================

# SearXNG Configuration (Self-hosted search)
SEARXNG_URL=http://localhost:8080

# ERPNext Integration
ERPNEXT_URL=https://your-erpnext-instance.com
ERPNEXT_API_KEY=your_api_key
ERPNEXT_API_SECRET=your_api_secret

# Meta / Facebook Graph API
META_ACCESS_TOKEN=your_meta_access_token

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BEARER_TOKEN=your_whatsapp_token

# Telegram Bot API
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Database Configuration
DATABASE_URL=sqlite:///community_database/growth_specialist.db

# Approval Mode: MANUAL, ASSISTED, AUTOMATED
APPROVAL_MODE=ASSISTED
